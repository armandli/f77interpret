{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(find ~/.claude -path *agent-memory* -name *.md)",
      "Bash(find ~/.claude/skills -name *.md)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(chmod:*)",
      "Bash(cmake -B build -S .)",
      "Bash(cmake --build build)",
      "Bash(./build/bin/f77interpret)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Read(//opt/homebrew/lib/cmake/**)",
      "Bash(find /Users/armandli/f77interpret/src -type f \\\\\\( -name \"*.cpp\" -o -name \"*.h\" -o -name \"*.hpp\" \\\\\\) -exec wc -l {} +)",
      "Bash(git mv:*)",
      "Bash(cmake -B build -DCMAKE_BUILD_TYPE=Release)",
      "Bash(./build/bin/f77interpret --help)",
      "Bash(./build/bin/f77interpret /nonexistent.f)",
      "Bash(echo \"exit: $?\")",
      "Bash(make)",
      "Bash(make test:*)",
      "Bash(xargs ls:*)",
      "Bash(xargs cat:*)",
      "Bash(find /Users/armandli/.claude/plugins -type f -name *.md -o -name *.txt)",
      "Bash(find /Users/armandli/.claude/plugins/marketplaces -type f -name *.md)",
      "Bash(cmake --build /Users/armandli/f77interpret/build)",
      "Bash(build/bin/f77interpret_test 2>&1)",
      "Bash(build/bin/f77interpret_test)",
      "Read(//Users/armandli/.claude/skills/**)",
      "Bash(cmake --build .)",
      "Bash(find /Users/armandli/.claude/plugins/marketplaces -name *.md)",
      "Bash(find /Users/armandli/.claude/plugins/data -name *.md)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-mermaid.sh\""
          }
        ]
      }
    ]
  }
}
